# --- Server ---
# Port the server listens on. Railway injects PORT in production — leave unset there.
PORT=3000
# Runtime environment: development | production | test
NODE_ENV=development
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Anthropic ---
# Server-side Anthropic API key. NEVER expose to the client.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase ---
# Your Supabase project URL.
SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase service role key. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: only needed if the project still uses HS256 legacy JWTs. Prefer JWKS-based verification.
SUPABASE_JWT_SECRET=your-legacy-hs256-secret-or-leave-blank

# --- CORS ---
# Comma-separated list of allowed origins. No wildcards in production.
ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# --- Rate limiting (per authenticated user) ---
# Window length in milliseconds (default: 1 minute).
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per window per user.
RATE_LIMIT_MAX=30
